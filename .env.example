# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to git

# ── Google Sheets ────────────────────────────────────────────────
# Sheet ID from: https://docs.google.com/spreadsheets/d/{SHEET_ID}/edit
# The sheet must be published or have link-sharing enabled
VITE_GOOGLE_SHEET_ID=1ETrRr3oEyNJ3aQBGzw1Kf3GkHCJuGZFqe12bB81Lqi0

# ── Linear API ───────────────────────────────────────────────────
# Read-only personal API key
# Get from: Linear → Settings → API → Personal API keys
VITE_LINEAR_API_KEY=lin_api_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Linear user ID to filter tickets by creator
# Get from: Linear → Profile URL or API query
VITE_LINEAR_USER_ID=d8c35a4f-7455-4d27-88e4-a57cfbc84757
